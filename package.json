{
  "name": "open-locally",
  "displayName": "Open Locally",
  "description": "Open or reveal remote/dev-container files through configurable local path mappings.",
  "version": "0.0.1",
  "publisher": "your-publisher-name",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:openLocally.open",
    "onCommand:openLocally.reveal",
    "onCommand:openLocally.copyPath"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openLocally.open",
        "title": "Open Locally",
        "category": "Open Locally"
      },
      {
        "command": "openLocally.reveal",
        "title": "Reveal Locally",
        "category": "Open Locally"
      },
      {
        "command": "openLocally.copyPath",
        "title": "Copy Local Path",
        "category": "Open Locally"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "openLocally.open",
          "group": "navigation@50"
        },
        {
          "command": "openLocally.reveal",
          "group": "navigation@51"
        },
        {
          "command": "openLocally.copyPath",
          "group": "navigation@52"
        }
      ]
    },
    "configuration": {
      "title": "Open Locally",
      "properties": {
        "openLocally.mappings": {
          "type": "array",
          "default": [],
          "description": "Map remote/container path prefixes to local host path prefixes.",
          "items": {
            "type": "object",
            "required": [
              "remote",
              "local"
            ],
            "properties": {
              "remote": {
                "type": "string",
                "description": "Remote/container path prefix, for example /workspaces/project"
              },
              "local": {
                "type": "string",
                "description": "Local path prefix, for example Z:/project or //server/share/project"
              }
            }
          }
        },
        "openLocally.showInfoMessages": {
          "type": "boolean",
          "default": true,
          "description": "Show confirmation messages after copy/open actions."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "echo \"No linter configured\""
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5",
    "@vscode/vsce": "^2.32.0"
  }
}
