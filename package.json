{
  "name": "open-locally",
  "displayName": "Open Locally",
  "description": "Open or reveal remote/dev-container files through configurable local path mappings.",
  "version": "1.0.0",
  "publisher": "your-publisher-name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gitmodimo/vscode-open-locally.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:openLocally.open",
    "onCommand:openLocally.reveal",
    "onCommand:openLocally.copyPath",
    "onCommand:openLocally.showLog"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openLocally.open",
        "title": "Open Locally",
        "category": "Open Locally"
      },
      {
        "command": "openLocally.reveal",
        "title": "Reveal Locally",
        "category": "Open Locally"
      },
      {
        "command": "openLocally.copyPath",
        "title": "Copy Local Path",
        "category": "Open Locally"
      },
      {
        "command": "openLocally.showLog",
        "title": "Show Log",
        "category": "Open Locally"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "openLocally.open",
          "group": "navigation@50",
          "when": "resourceScheme == file || resourceScheme == vscode-remote"
        },
        {
          "command": "openLocally.reveal",
          "group": "navigation@51",
          "when": "resourceScheme == file || resourceScheme == vscode-remote"
        },
        {
          "command": "openLocally.copyPath",
          "group": "navigation@52",
          "when": "resourceScheme == file || resourceScheme == vscode-remote"
        }
      ]
    },
    "configuration": {
      "title": "Open Locally",
      "order": 10,
      "properties": {
        "openLocally.mappings": {
          "type": "object",
          "default": {},
          "scope": "resource",
          "order": 10,
          "additionalProperties": {
            "type": "string"
          },
          "description": "Path mappings from remote or container prefixes to local host prefixes. Keys are remote prefixes, values are local host prefixes. The longest matching remote prefix is used.",
          "markdownDescription": "Path mappings from remote or container prefixes to local host prefixes. Keys are remote prefixes, values are local host prefixes. The longest matching remote prefix is used.\n\nExample: key `/workspaces/project`, value `Z:/project`."
        },
        "openLocally.showInfoMessages": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "order": 20,
          "description": "Show confirmation messages after copy/open actions."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "echo \"No linter configured\""
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^5.4.5"
  }
}
